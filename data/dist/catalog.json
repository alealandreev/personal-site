  "sample_queries": [
    {
      "id": "content-by-topic",
      "title": "Which topics appear most often?",
      "sql": "SELECT tag, COUNT(*) AS mentions\nFROM (\n  SELECT UNNEST(STRING_SPLIT(tags, '|')) AS tag FROM posts\n  UNION ALL\n  SELECT UNNEST(STRING_SPLIT(tags, '|')) AS tag FROM til\n  UNION ALL\n  SELECT UNNEST(STRING_SPLIT(tags, '|')) AS tag FROM projects\n)\nGROUP BY tag\nORDER BY mentions DESC;"
    },
    {
      "id": "writing-density",
      "title": "How much long-form writing exists?",
      "sql": "SELECT locale, COUNT(*) AS posts, SUM(word_count) AS words\nFROM posts\nGROUP BY locale\nORDER BY words DESC;"
    },
    {
      "id": "coding-language-mix",
      "title": "What is the coding language mix?",
      "sql": "SELECT language, percent, hours_estimate\nFROM coding_stats\nORDER BY percent DESC;"
    },
    {
      "id": "ai-data-projects",
      "title": "Which projects connect AI tooling and data platforms?",
      "sql": "SELECT title, status, tags, url\nFROM projects\nWHERE tags LIKE '%llm%' OR tags LIKE '%rag%' OR tags LIKE '%duckdb%'\nORDER BY date DESC;"
    }
  ]
